From a4a00feabac6802f2cc164f6c3874eb3c24360e4 Mon Sep 17 00:00:00 2001
From: Mika Senghaas <mail@mikasenghaas.de>
Date: Tue, 24 Feb 2026 20:15:34 +0000
Subject: [PATCH 1/6] fix: pass explicit step to wandb.log in orchestrator

Without an explicit step, wandb auto-increments its internal counter,
causing subsequent calls with explicit step values to trigger
"step N is less than current step N+1" warnings.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 src/prime_rl/orchestrator/eval_utils.py   | 2 +-
 src/prime_rl/orchestrator/orchestrator.py | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/prime_rl/orchestrator/eval_utils.py b/src/prime_rl/orchestrator/eval_utils.py
index 6b3904b7c2..e2c39facdb 100644
--- a/src/prime_rl/orchestrator/eval_utils.py
+++ b/src/prime_rl/orchestrator/eval_utils.py
@@ -144,4 +144,4 @@ async def evaluate_env(
     eval_metrics = {**{f"eval/{env_name}/{k}": v for k, v in eval_metrics.items()}}
     eval_metrics.update({"progress/ckpt_step": ckpt_step, "step": step or ckpt_step})
     monitor = get_monitor()
-    monitor.log(eval_metrics, step=None)
+    monitor.log(eval_metrics, step=step or ckpt_step)
diff --git a/src/prime_rl/orchestrator/orchestrator.py b/src/prime_rl/orchestrator/orchestrator.py
index 8f2606201c..a1f969b6a6 100644
--- a/src/prime_rl/orchestrator/orchestrator.py
+++ b/src/prime_rl/orchestrator/orchestrator.py
@@ -716,7 +716,7 @@ def process_rollout(rollout: vf.RolloutOutput, rollout_idx: int) -> list[Trainin
                 to_log.update({f"val_batch/{env}": ratio for env, ratio in per_env_ratio.items()})
 
         # Log metrics to monitor(s)
-        monitor.log(to_log)
+        monitor.log(to_log, step=progress.step)
 
         # Log samples to monitor(s) if enabled
         subset_train_rollouts = random.sample(train_rollouts, min(8, len(train_rollouts)))

From 6b7f290dd38e60f752999d73553a2870df0f83c4 Mon Sep 17 00:00:00 2001
From: Mika Senghaas <mail@mikasenghaas.de>
Date: Tue, 24 Feb 2026 20:57:45 +0000
Subject: [PATCH 2/6] fix: use explicit None check for step=0 in eval_utils

`step or ckpt_step` treats step=0 as falsy, silently substituting
ckpt_step. Use `step if step is not None else ckpt_step` instead.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 src/prime_rl/orchestrator/eval_utils.py | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/src/prime_rl/orchestrator/eval_utils.py b/src/prime_rl/orchestrator/eval_utils.py
index e2c39facdb..2b63481de7 100644
--- a/src/prime_rl/orchestrator/eval_utils.py
+++ b/src/prime_rl/orchestrator/eval_utils.py
@@ -142,6 +142,7 @@ async def evaluate_env(
         assert pass_at_k is not None
         eval_metrics.update(pd.Series(pass_at_k.mean()).to_dict())
     eval_metrics = {**{f"eval/{env_name}/{k}": v for k, v in eval_metrics.items()}}
-    eval_metrics.update({"progress/ckpt_step": ckpt_step, "step": step or ckpt_step})
+    effective_step = step if step is not None else ckpt_step
+    eval_metrics.update({"progress/ckpt_step": ckpt_step, "step": effective_step})
     monitor = get_monitor()
-    monitor.log(eval_metrics, step=step or ckpt_step)
+    monitor.log(eval_metrics, step=effective_step)

From 612f8eba4a4130467fd9f5b57c30630106ea583b Mon Sep 17 00:00:00 2001
From: Mika Senghaas <mail@mikasenghaas.de>
Date: Tue, 24 Feb 2026 20:59:33 +0000
Subject: [PATCH 3/6] simplify: step is always an int, drop Optional and
 fallback

Both call sites always pass step=progress.step (int), so remove the
None type and the ckpt_step fallback that was broken for step=0.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 src/prime_rl/orchestrator/eval_utils.py | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/src/prime_rl/orchestrator/eval_utils.py b/src/prime_rl/orchestrator/eval_utils.py
index 2b63481de7..44f901c6b4 100644
--- a/src/prime_rl/orchestrator/eval_utils.py
+++ b/src/prime_rl/orchestrator/eval_utils.py
@@ -71,7 +71,7 @@ async def evaluate_env(
     rollouts_per_example: int,
     max_retries: int,
     ckpt_step: int,
-    step: int | None,
+    step: int,
     get_client: Callable[[], Awaitable[vf.ClientConfig]],
 ):
     logger = get_logger()
@@ -142,7 +142,6 @@ async def evaluate_env(
         assert pass_at_k is not None
         eval_metrics.update(pd.Series(pass_at_k.mean()).to_dict())
     eval_metrics = {**{f"eval/{env_name}/{k}": v for k, v in eval_metrics.items()}}
-    effective_step = step if step is not None else ckpt_step
-    eval_metrics.update({"progress/ckpt_step": ckpt_step, "step": effective_step})
+    eval_metrics.update({"progress/ckpt_step": ckpt_step, "step": step})
     monitor = get_monitor()
-    monitor.log(eval_metrics, step=effective_step)
+    monitor.log(eval_metrics, step=step)

From bf679db5f4069374a74d409c0064cd04d8091c6b Mon Sep 17 00:00:00 2001
From: Mika Senghaas <mail@mikasenghaas.de>
Date: Tue, 24 Feb 2026 21:01:13 +0000
Subject: [PATCH 4/6] fix: commit immediately on wandb.log to avoid delayed
 dashboard data

With explicit step=, wandb accumulates without committing until it sees
a new step. Adding commit=True flushes data to the dashboard immediately.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 src/prime_rl/utils/monitor/wandb.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/prime_rl/utils/monitor/wandb.py b/src/prime_rl/utils/monitor/wandb.py
index ec6f69254b..428517718a 100644
--- a/src/prime_rl/utils/monitor/wandb.py
+++ b/src/prime_rl/utils/monitor/wandb.py
@@ -77,7 +77,7 @@ def log(self, metrics: dict[str, Any], step: int | None = None) -> None:
             return
         if not self.enabled:
             return
-        wandb.log(metrics, step=step)
+        wandb.log(metrics, step=step, commit=True)
 
     def log_samples(self, rollouts: list[vf.RolloutOutput], step: int) -> None:
         """Logs rollouts to W&B table."""
@@ -122,7 +122,7 @@ def log_samples(self, rollouts: list[vf.RolloutOutput], step: int) -> None:
             self.samples_table.add_data(*sample.values())
             self.samples.append(sample)
 
-        wandb.log({"samples": self.samples_table}, step=step)
+        wandb.log({"samples": self.samples_table}, step=step, commit=True)
         self.last_log_samples_step = step
         self.logger.debug(f"Logged samples at step {step} to W&B table in {time.perf_counter() - start_time:.2f}s")
 

